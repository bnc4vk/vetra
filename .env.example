# Copy this file to .env.local and add a newly rotated project key.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_PROJECT_ID=your_openai_project_id_here

# Fail-closed billing safeguard. Leave false until this exact project says
# "You're enrolled for complimentary daily tokens" in OpenAI Platform settings.
OPENAI_COMPLIMENTARY_TOKENS_CONFIRMED=false

# The server pins gpt-5.4-2026-03-05 because complimentary-token eligibility
# is snapshot-specific. It cannot be overridden from the environment.

# Set this to the threshold shown for your usage tier: 250000 for tiers 1-2,
# or 1000000 for tiers 3-5. Vetra enforces a ceiling at 90% of this value.
OPENAI_COMPLIMENTARY_DAILY_TOKEN_LIMIT=250000

# Before starting a test run, copy today's combined token usage for the eligible
# model group from the Usage dashboard. This protects against non-Vetra usage.
OPENAI_COMPLIMENTARY_TOKENS_USED_AT_START=0

# Optional. Defaults to 5173.
PORT=5173

# Hosted deployment only. GitHub Pages sends GPT requests to the server-side API
# configured by VITE_API_BASE_URL; never place OPENAI_API_KEY in a VITE_ variable.
VITE_API_BASE_URL=
# Optional. Enables Google Identity Services in the rewards connection modal.
# Configure this as an OAuth 2.0 Web client and allow the app's browser origins.
VITE_GOOGLE_CLIENT_ID=
VETRA_ALLOWED_ORIGINS=https://bnc4vk.github.io,http://localhost:5173
VETRA_MAX_REQUESTS_PER_IP_PER_DAY=12
OPENAI_HOSTED_SAFE_FRACTION=0.4
# Vercel's Upstash integration supplies KV_REST_API_URL and KV_REST_API_TOKEN.
# The UPSTASH_* aliases are also accepted for direct Upstash deployments.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
